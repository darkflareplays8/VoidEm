{
  "identifier": "default",
  "description": "Default capabilities for VoidInstaller",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-unlisten",
    "core:window:allow-start-dragging",
    "shell:allow-execute",
    "shell:allow-open",
    "opener:allow-open-path",
    "opener:allow-open-url"
  ]
}