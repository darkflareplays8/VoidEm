{
  "identifier": "default",
  "description": "Default capabilities for VoidEmulator",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-unlisten",
    "core:window:allow-start-dragging",
    "shell:allow-execute",
    "shell:allow-open"
  ]
}